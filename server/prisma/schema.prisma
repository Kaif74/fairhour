// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum RequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExchangeStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum ConversationStatus {
  ACTIVE
  LOCKED
}

// ============================================================================
// MODELS
// ============================================================================

/// User model - represents platform users who can provide and request services
model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  passwordHash    String
  location        String?
  reputationScore Float    @default(0)
  hasOnboarded    Boolean  @default(false)
  skills          String[] @default([])
  bio             String?
  profileImageUrl String?
  availability    String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  services             Service[]
  requestsMade         Request[]  @relation("RequesterRequests")
  exchangesAsProvider  Exchange[] @relation("ProviderExchanges")
  exchangesAsRequester Exchange[] @relation("RequesterExchanges")
  conversationsAsUserA Conversation[] @relation("UserAConversations")
  conversationsAsUserB Conversation[] @relation("UserBConversations")
  messages             Message[]

  @@index([email])
}

/// Service model - represents services offered by users
model Service {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  category    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchanges Exchange[]

  @@index([userId])
  @@index([category])
  @@index([isActive])
}

/// Request model - represents requests for services from users
model Request {
  id              String        @id @default(uuid())
  requesterId     String
  title           String
  serviceCategory String
  description     String
  hours           Float         @default(1)
  status          RequestStatus @default(OPEN)
  createdAt       DateTime      @default(now())

  // Relations
  requester User @relation("RequesterRequests", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([requesterId])
  @@index([status])
  @@index([serviceCategory])
}

/// Exchange model - represents time transactions between users
model Exchange {
  id                  String         @id @default(uuid())
  providerId          String
  requesterId         String
  serviceId           String?
  hours               Float
  status              ExchangeStatus @default(PENDING)
  providerConfirmed   Boolean        @default(false)  // Provider marks service as delivered
  requesterConfirmed  Boolean        @default(false)  // Requester confirms service received
  createdAt           DateTime       @default(now())
  completedAt         DateTime?

  // Relations
  provider  User @relation("ProviderExchanges", fields: [providerId], references: [id], onDelete: Cascade)
  requester User @relation("RequesterExchanges", fields: [requesterId], references: [id], onDelete: Cascade)
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  conversation Conversation?

  @@index([providerId])
  @@index([requesterId])
  @@index([status])
  @@index([serviceId])
}

model Conversation {
  id            String             @id @default(uuid())
  exchangeId    String             @unique
  userAId       String
  userBId       String
  status        ConversationStatus @default(ACTIVE)
  serviceTitle  String?
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  exchange Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  userA    User     @relation("UserAConversations", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User     @relation("UserBConversations", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userAId])
  @@index([userBId])
  @@index([status])
  @@index([lastMessageAt])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
  @@index([senderId])
}

