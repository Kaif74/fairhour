// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum RequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExchangeStatus {
  PENDING
  ACCEPTED
  ACTIVE
  COMPLETED
}

enum ConversationStatus {
  ACTIVE
  LOCKED
}

enum DeclaredExperienceLevel {
  BEGINNER @map("beginner")
  INTERMEDIATE @map("intermediate")
  EXPERT @map("expert")
}

enum SkillProofType {
  CERTIFICATE @map("certificate")
  PORTFOLIO   @map("portfolio")
  LINK        @map("link")
  IMAGE       @map("image")
}

enum ProofVoteType {
  VALID      @map("valid")
  IRRELEVANT @map("irrelevant")
  FAKE       @map("fake")
}

enum CredibilityEventType {
  JOB_COMPLETED @map("job_completed")
  REVIEW_ADDED  @map("review_added")
  DISPUTE       @map("dispute")
  PROOF_ADDED   @map("proof_added")
}

enum OtpPhase {
  START      @map("start")
  COMPLETION @map("completion")
}

enum OtpGeneratedFor {
  PROVIDER @map("provider")
  RECEIVER @map("receiver")
}

// ============================================================================
// MODELS
// ============================================================================

/// User model - represents platform users who can provide and request services
model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  passwordHash    String
  location        String?
  reputationScore Float    @default(0)
  hasOnboarded    Boolean  @default(false)
  skills          String[] @default([])
  bio             String?
  profileImageUrl String?
  availability    String[] @default([])
  walletAddress   String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  services             Service[]
  requestsMade         Request[]  @relation("RequesterRequests")
  exchangesAsProvider  Exchange[] @relation("ProviderExchanges")
  exchangesAsRequester Exchange[] @relation("RequesterExchanges")
  conversationsAsUserA Conversation[] @relation("UserAConversations")
  conversationsAsUserB Conversation[] @relation("UserBConversations")
  messages             Message[]
  reviewsGiven         Review[]   @relation("ReviewsGiven")
  reviewsReceived      Review[]   @relation("ReviewsReceived")
  skillExperiences     UserSkillExperience[]
  skillProofs          UserSkillProof[]
  proofVotes           ProofVote[]
  credibilityEvents    CredibilityEvent[]

  @@index([email])
}

/// Service model - represents services offered by users
model Service {
  id           String   @id @default(uuid())
  userId       String
  title        String
  description  String
  category     String
  occupationId String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation Occupation? @relation(fields: [occupationId], references: [id], onDelete: SetNull)
  exchanges  Exchange[]

  @@index([userId])
  @@index([category])
  @@index([isActive])
  @@index([occupationId])
}

/// Request model - represents requests for services from users
model Request {
  id              String        @id @default(uuid())
  requesterId     String
  title           String
  serviceCategory String
  description     String
  hours           Float         @default(1)
  status          RequestStatus @default(OPEN)
  createdAt       DateTime      @default(now())

  // Relations
  requester User @relation("RequesterRequests", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([requesterId])
  @@index([status])
  @@index([serviceCategory])
}

/// Exchange model - represents time transactions between users
model Exchange {
  id                  String         @id @default(uuid())
  providerId          String
  requesterId         String
  serviceId           String?
  hours               Float
  creditsEarned       Float?         // Credits calculated by SkillValuationEngine
  occupationCode      String?        // NCO occupation code at time of exchange
  valuationDetails    Json?          // Breakdown: { skill_multiplier, reputation_factor, demand_factor, total_multiplier }
  blockchainTxHash    String?        @unique // Immutable receipt hash on Ethereum network
  status              ExchangeStatus @default(PENDING)
  providerConfirmed   Boolean        @default(false)  // Provider marks service as delivered
  requesterConfirmed  Boolean        @default(false)  // Requester confirms service received
  createdAt           DateTime       @default(now())
  startedAt           DateTime?
  completedAt         DateTime?

  // Relations
  provider     User          @relation("ProviderExchanges", fields: [providerId], references: [id], onDelete: Cascade)
  requester    User          @relation("RequesterExchanges", fields: [requesterId], references: [id], onDelete: Cascade)
  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  conversation Conversation?
  reviews      Review[]
  otpSessions  ServiceOtp[]

  @@index([providerId])
  @@index([requesterId])
  @@index([status])
  @@index([serviceId])
}

model Conversation {
  id            String             @id @default(uuid())
  exchangeId    String             @unique
  userAId       String
  userBId       String
  status        ConversationStatus @default(ACTIVE)
  serviceTitle  String?
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  exchange Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  userA    User     @relation("UserAConversations", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User     @relation("UserBConversations", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userAId])
  @@index([userBId])
  @@index([status])
  @@index([lastMessageAt])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
  @@index([senderId])
}

// ============================================================================
// SKILL VALUATION MODELS
// ============================================================================

/// Occupation model - NCO-2015 occupation classification for skill valuation
model Occupation {
  id             String   @id @default(uuid())
  ncoCode        String   @unique
  title          String
  majorGroup     String
  skillLevel     Int      // 1=Elementary, 2=Skilled, 3=Technical, 4=Professional
  baseMultiplier Float    // 1.0, 1.2, 1.5, 1.8
  description    String?
  createdAt      DateTime @default(now())

  // Relations
  services          Service[]
  serviceStats      ServiceStats?
  skillExperiences  UserSkillExperience[]
  skillProofs       UserSkillProof[]
  credibilityEvents CredibilityEvent[]

  @@index([majorGroup])
  @@index([skillLevel])
}

/// ServiceStats model - demand metrics for occupations
model ServiceStats {
  id                 String   @id @default(uuid())
  occupationId       String   @unique
  requestsLast30Days Int      @default(0)
  providersAvailable Int      @default(1)
  demandRatio        Float    @default(1.0)
  updatedAt          DateTime @updatedAt

  // Relations
  occupation Occupation @relation(fields: [occupationId], references: [id], onDelete: Cascade)
}

/// Review model - ratings and reviews for completed exchanges
model Review {
  id         String   @id @default(uuid())
  exchangeId String
  reviewerId String
  providerId String
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  // Relations
  exchange Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  reviewer User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  provider User     @relation("ReviewsReceived", fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([exchangeId, reviewerId]) // One review per person per exchange
  @@index([providerId])
  @@index([reviewerId])
}

model UserSkillExperience {
  id              String                  @id @default(uuid())
  userId          String                  @map("user_id")
  occupationId    String                  @map("occupation_id")
  declaredLevel   DeclaredExperienceLevel @default(BEGINNER) @map("declared_level")
  experienceScore Float                   @default(0) @map("experience_score")
  jobsCompleted   Int                     @default(0) @map("jobs_completed")
  avgRating       Float                   @default(0) @map("avg_rating")
  repeatClients   Int                     @default(0) @map("repeat_clients")
  disputeCount    Int                     @default(0) @map("dispute_count")
  lastUpdated     DateTime                @updatedAt @map("last_updated")
  createdAt       DateTime                @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation Occupation @relation(fields: [occupationId], references: [id], onDelete: Cascade)

  @@unique([userId, occupationId])
  @@index([userId])
  @@index([occupationId])
  @@map("user_skill_experience")
}

model UserSkillProof {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  occupationId String         @map("occupation_id")
  proofType    SkillProofType @map("proof_type")
  proofUrl     String         @map("proof_url")
  description  String?
  isVerified   Boolean        @default(false) @map("is_verified")
  createdAt    DateTime       @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation Occupation @relation(fields: [occupationId], references: [id], onDelete: Cascade)
  votes      ProofVote[]

  @@index([userId])
  @@index([occupationId])
  @@index([isVerified])
  @@map("user_skill_proofs")
}

model ProofVote {
  id        String        @id @default(uuid())
  proofId   String        @map("proof_id")
  voterId   String        @map("voter_id")
  voteType  ProofVoteType @map("vote_type")
  createdAt DateTime      @default(now()) @map("created_at")

  proof  UserSkillProof @relation(fields: [proofId], references: [id], onDelete: Cascade)
  voter  User           @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([proofId, voterId])
  @@index([proofId])
  @@index([voterId])
  @@map("proof_votes")
}

model CredibilityEvent {
  id           String               @id @default(uuid())
  userId       String               @map("user_id")
  occupationId String               @map("occupation_id")
  eventType    CredibilityEventType @map("event_type")
  metadata     Json
  createdAt    DateTime             @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation Occupation @relation(fields: [occupationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([occupationId])
  @@index([eventType])
  @@map("credibility_events")
}

model ServiceOtp {
  id               String          @id @default(uuid())
  exchangeId       String          @map("service_id")
  phase            OtpPhase
  otpHash          String          @map("otp_hash")
  generatedFor     OtpGeneratedFor @map("generated_for")
  verified         Boolean         @default(false)
  verifiedAt       DateTime?       @map("verified_at")
  failedAttempts   Int             @default(0) @map("failed_attempts")
  failedAttemptLog Json?           @map("failed_attempt_log")
  invalidatedAt    DateTime?       @map("invalidated_at")
  expiresAt        DateTime        @map("expires_at")
  createdAt        DateTime        @default(now()) @map("created_at")

  exchange Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)

  @@index([exchangeId, phase])
  @@index([expiresAt])
  @@index([invalidatedAt])
  @@map("service_otps")
}
