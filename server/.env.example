# =============================================================================
# FairHour Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# DATABASE (Required)
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# Examples:
# Local:  postgresql://postgres:password@localhost:5432/fairhour?schema=public
# Remote: postgresql://user:pass@db.example.com:5432/fairhour?schema=public
# Render: postgresql://user:pass@dpg-xxx.oregon-postgres.render.com/fairhour
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres

DATABASE_URL="postgresql://user:password@localhost:5432/fairhour?schema=public"

# =============================================================================
# JWT AUTHENTICATION (Required in production)
# =============================================================================
# Secret key for signing JWT tokens (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# Token expiration (examples: "1h", "7d", "30d")
JWT_EXPIRES_IN="7d"

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Port the server will listen on
PORT=5000

# Environment: "development" or "production"
NODE_ENV="development"

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Frontend URL that's allowed to access the API
# Development: http://localhost:3000 (Vite default)
# Production: https://your-frontend-domain.com

CORS_ORIGIN="http://localhost:3000"

# =============================================================================
# SOCKET.IO CONFIGURATION
# =============================================================================

# Socket.IO path (optional)
SOCKET_PATH="/socket.io"

# =============================================================================
# CHAT CONFIGURATION
# =============================================================================

# Max length for a single message
CHAT_MESSAGE_MAX_LENGTH=2000

# Rate limit for chat messages (per user)
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=30

# =============================================================================
# REDIS (Optional - for scaling Socket.IO)
# =============================================================================

# REDIS_URL="redis://localhost:6379"
