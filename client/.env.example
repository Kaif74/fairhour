# FairHour Client Environment Configuration

# Backend API URL - Must match where your server is running
VITE_API_URL=http://localhost:5000

# Socket.IO URL (optional, defaults to VITE_API_URL)
VITE_SOCKET_URL=http://localhost:5000

# Socket.IO path (optional, defaults to /socket.io)
VITE_SOCKET_PATH=/socket.io
